/* ==========================
   GLOBAL
========================== */

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
scroll-behavior:smooth;
}

body{
background:#0d1117;
color:#ffffff;
line-height:1.6;
}

img{
width:100%;
display:block;
}

a{
text-decoration:none;
}

section{
padding:80px 8%;
}

.title{
text-align:center;
font-size:38px;
margin-bottom:50px;
color:#00e5ff;
}

/* ==========================
HEADER
========================== */

header{
position:fixed;
top:0;
left:0;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 8%;
background:rgba(0,0,0,.75);
backdrop-filter:blur(10px);
z-index:1000;
}

.logo{
font-size:28px;
font-weight:bold;
color:#00e5ff;
}

.logo i{
margin-right:8px;
}

nav a{
margin-left:30px;
color:white;
font-weight:bold;
transition:.3s;
}

nav a:hover{
color:#00e5ff;
}

#themeBtn{
background:#00e5ff;
border:none;
padding:10px 14px;
border-radius:50%;
cursor:pointer;
font-size:18px;
}

/* ==========================
HERO
========================== */

.hero{
display:flex;
align-items:center;
justify-content:space-between;
gap:60px;
min-height:100vh;
}

.hero-text{
flex:1;
}

.hero-text h1{
font-size:55px;
margin-bottom:20px;
}

.hero-text p{
font-size:20px;
margin-bottom:30px;
color:#d8d8d8;
}

.hero-image{
flex:1;
}

.hero-image img{
border-radius:15px;
box-shadow:0 0 30px rgba(0,229,255,.4);
}

.buttons{
display:flex;
gap:20px;
}

.btn{
background:#00e5ff;
padding:15px 30px;
border-radius:8px;
color:black;
font-weight:bold;
}

.btn2{
border:2px solid #00e5ff;
padding:15px 30px;
border-radius:8px;
color:#00e5ff;
}

/* ==========================
SERVICES
========================== */

.service-container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
}

.card{
background:#161b22;
padding:35px;
border-radius:15px;
text-align:center;
transition:.4s;
border:1px solid #202830;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 25px rgba(0,229,255,.3);
}

.card i{
font-size:45px;
margin-bottom:20px;
color:#00e5ff;
}

.card h3{
margin-bottom:15px;
}

/* ==========================
INDUSTRIES
========================== */

.industries{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
}

.industries div{
background:#161b22;
padding:25px;
border-radius:12px;
text-align:center;
font-weight:bold;
transition:.3s;
}

.industries div:hover{
background:#00e5ff;
color:black;
}

/* ==========================
DASHBOARD
========================== */

.dashboard{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
}

.box{
background:#161b22;
padding:35px;
border-radius:15px;
text-align:center;
}

.box span{
display:block;
font-size:42px;
margin-top:15px;
font-weight:bold;
color:#00e5ff;
}

/* ==========================
WHY US
========================== */

.why ul{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
list-style:none;
}

.why li{
background:#161b22;
padding:20px;
border-radius:10px;
}

/* ==========================
CONTACT
========================== */

form{
max-width:700px;
margin:auto;
display:flex;
flex-direction:column;
gap:18px;
}

form input,
form textarea{

padding:16px;
border:none;
border-radius:8px;
background:#161b22;
color:white;
font-size:16px;
}

textarea{
height:160px;
resize:none;
}

form button{

padding:16px;
border:none;
border-radius:8px;
background:#00e5ff;
font-size:18px;
font-weight:bold;
cursor:pointer;
}

/* ==========================
FOOTER
========================== */

footer{
background:#05080d;
padding:40px;
text-align:center;
margin-top:60px;
}

footer h2{
color:#00e5ff;
margin-bottom:15px;
}

/* ==========================
WHATSAPP
========================== */

.whatsapp{

position:fixed;
bottom:25px;
right:25px;
width:65px;
height:65px;
background:#25D366;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
font-size:32px;
color:white;
box-shadow:0 0 20px rgba(0,0,0,.4);
}

/* ==========================
RESPONSIVE
========================== */

@media(max-width:992px){

.hero{

flex-direction:column;
text-align:center;
padding-top:120px;

}

.buttons{

justify-content:center;

}

nav{

display:none;

}

}

@media(max-width:600px){

.hero-text h1{

font-size:36px;

}

.title{

font-size:30px;

}

}
